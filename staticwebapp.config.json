{
  "routes": [
    { "route": "/admin", "rewrite": "/admin.html", "allowedRoles": ["rs"] },
    { "route": "/admin.html", "allowedRoles": ["rs"] },
    { "route": "/api/responses", "allowedRoles": ["rs"] },
    { "route": "/api/submit", "allowedRoles": ["anonymous"] }
  ],
  "responseOverrides": {
    "401": { "redirect": "/.auth/login/aad", "statusCode": 302 }
  },
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/api/*", "/admin.html", "/content.js", "*.{css,js,png,jpg,svg,ico}"]
  }
}
